@inject ITodoService TodoSvc
@inject ISnackbar    Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Folder" Class="mr-2" />
            @(ExistingProject != null ? "Modifier le projet" : "Nouveau projet")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudStack Spacing="3">
                <MudTextField @bind-Value="_name"
                              Label="Nom *"
                              Required RequiredError="Le nom est obligatoire."
                              Variant="Variant.Outlined"
                              MaxLength="100" />
                <MudTextField @bind-Value="_description"
                              Label="Description"
                              Lines="2"
                              Variant="Variant.Outlined" />
                <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                    <MudTextField @bind-Value="_color"
                                  Label="Couleur (hex)"
                                  Variant="Variant.Outlined"
                                  Placeholder="#1976D2" />
                    <div style="@($"width:40px;height:40px;border-radius:8px;background:{_color};flex-shrink:0;")"></div>
                </MudStack>
                <MudStack Row Wrap="Wrap.Wrap" Spacing="1">
                    @foreach (var c in _presetColors)
                    {
                        <div style="@($"width:32px;height:32px;border-radius:50%;background:{c};cursor:pointer;"
                                   + (_color == c ? "outline:3px solid #000;" : ""))"
                             @onclick="@(() => _color = c)" />
                    }
                </MudStack>
            </MudStack>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Annuler</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   Disabled="@(!_isValid || _saving)"
                   OnClick="SubmitAsync">
            @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate /> }
            else { <span>@(ExistingProject != null ? "Enregistrer" : "Créer")</span> }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private MudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public TodoProject? ExistingProject { get; set; }

    private MudForm? _form;
    private bool     _isValid;
    private bool     _saving;

    private string  _name        = string.Empty;
    private string? _description;
    private string  _color       = "#1976D2";

    private static readonly string[] _presetColors =
    [
        "#1565C0","#1976D2","#0288D1","#0097A7",
        "#2E7D32","#558B2F","#F57F17","#E65100",
        "#C62828","#AD1457","#6A1B9A","#4527A0",
        "#37474F","#455A64","#607D8B","#78909C"
    ];

    protected override void OnInitialized()
    {
        if (ExistingProject != null)
        {
            _name        = ExistingProject.Name;
            _description = ExistingProject.Description;
            _color       = ExistingProject.Color;
        }
    }

    private async Task SubmitAsync()
    {
        await _form!.Validate();
        if (!_isValid) return;

        _saving = true;
        try
        {
            if (ExistingProject != null)
                await TodoSvc.UpdateProjectAsync(ExistingProject.Id, _name, _description, _color);
            else
                await TodoSvc.CreateProjectAsync(_name, _description, _color);

            Snackbar.Add(
                ExistingProject != null ? "Projet mis à jour." : "Projet créé.",
                Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur : {ex.Message}", Severity.Error);
        }
        finally { _saving = false; }
    }

    private void Cancel() => MudDialog.Cancel();
}
