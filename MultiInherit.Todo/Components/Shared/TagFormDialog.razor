@inject ITodoService TodoSvc
@inject ISnackbar    Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Label" Class="mr-2" />
            @(ExistingTag != null ? "Modifier l'étiquette" : "Nouvelle étiquette")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudStack Spacing="3">
                <MudTextField @bind-Value="_label"
                              Label="Label *"
                              Required RequiredError="Le label est obligatoire."
                              Variant="Variant.Outlined"
                              MaxLength="50" />
                <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                    <MudTextField @bind-Value="_color"
                                  Label="Couleur (hex)"
                                  Variant="Variant.Outlined" />
                    <MudChip T="string"
                             Style="@($"background:{_color}33;color:{_color};border:1px solid {_color};")">
                        @(_label.Length > 0 ? _label : "Aperçu")
                    </MudChip>
                </MudStack>
                <MudStack Row Wrap="Wrap.Wrap" Spacing="1">
                    @foreach (var c in _presetColors)
                    {
                        <div style="@($"width:28px;height:28px;border-radius:50%;background:{c};cursor:pointer;"
                                   + (_color == c ? "outline:3px solid #000;" : ""))"
                             @onclick="@(() => _color = c)" />
                    }
                </MudStack>
            </MudStack>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Annuler</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   Disabled="@(!_isValid || _saving)"
                   OnClick="SubmitAsync">
            @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate /> }
            else { <span>@(ExistingTag != null ? "Enregistrer" : "Créer")</span> }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private MudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public TodoTag? ExistingTag { get; set; }

    private MudForm? _form;
    private bool     _isValid;
    private bool     _saving;

    private string _label = string.Empty;
    private string _color = "#607D8B";

    private static readonly string[] _presetColors =
    [
        "#F44336","#E91E63","#9C27B0","#673AB7",
        "#3F51B5","#2196F3","#03A9F4","#00BCD4",
        "#009688","#4CAF50","#8BC34A","#CDDC39",
        "#FFC107","#FF9800","#FF5722","#607D8B"
    ];

    protected override void OnInitialized()
    {
        if (ExistingTag != null)
        {
            _label = ExistingTag.Label;
            _color = ExistingTag.Color;
        }
    }

    private async Task SubmitAsync()
    {
        await _form!.Validate();
        if (!_isValid) return;

        _saving = true;
        try
        {
            if (ExistingTag != null)
                await TodoSvc.UpdateTagAsync(ExistingTag.Id, _label, _color);
            else
                await TodoSvc.CreateTagAsync(_label, _color);

            Snackbar.Add(
                ExistingTag != null ? "Étiquette mise à jour." : "Étiquette créée.",
                Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur : {ex.Message}", Severity.Error);
        }
        finally { _saving = false; }
    }

    private void Cancel() => MudDialog.Cancel();
}
